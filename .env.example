# ===========================================
# AMOS Dashboard - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Database (Neon / Vercel Postgres)
# Get these from: Neon Console → amos-dashboard → Connection Details
NEON_DATABASE_URL="postgresql://neondb_owner:<password>@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
NEON_DIRECT_URL="postgresql://neondb_owner:<password>@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Node environment
NODE_ENV="production"