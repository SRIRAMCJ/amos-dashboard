# ===========================================
# AMOS Dashboard - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Database (Neon / Vercel Postgres)
# Get these from: Neon Console → amos-dashboard → Connection Details
NEON_DATABASE_URL="postgresql://neondb_owner:<password>@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
NEON_DIRECT_URL="postgresql://neondb_owner:<password>@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# AI Provider (FREE, open-source models — pick ONE)
#
# Option 1 (RECOMMENDED — fastest, no cold start):
#   Get a free key from: https://console.groq.com/keys
#   Model: Llama-3.1-8B (open-source, sub-second responses)
GROQ_API_KEY=""
#
# Option 2 (alternative — may have cold start delays):
#   Get a free token from: https://huggingface.co/settings/tokens
#   Model: Mistral-7B-Instruct (open-source, Apache 2.0)
HF_TOKEN=""

# Node environment
NODE_ENV="production"