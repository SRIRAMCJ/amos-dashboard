# ===========================================
# AMOS Dashboard - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Database (Vercel Postgres / Neon)
# Get these from: Vercel Dashboard → Storage → Your Postgres DB → .env.local
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/amos-db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/amos-db?sslmode=require"

# Node environment
NODE_ENV="production"